{
  "name": "@hashhive/backend",
  "version": "1.0.0",
  "private": true,
  "description": "HashHive backend API server — Hono on Bun.serve()",
  "type": "module",
  "scripts": {
    "dev": "bun --hot src/index.ts",
    "build": "bun build src/index.ts --outdir dist --target bun",
    "start": "bun dist/index.js",
    "worker:tasks": "bun src/worker-task-generation.ts",
    "worker:jobs": "bun src/worker-jobs.ts",
    "test": "TASKS_TEST_ISOLATED=1 bun test --preload ./tests/preload.ts tests/unit/tasks.test.ts && bun test --preload ./tests/preload.ts",
    "lint": "biome check ./src",
    "type-check": "tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "3.1017.0",
    "@aws-sdk/s3-request-presigner": "3.1017.0",
    "@hashhive/shared": "workspace:*",
    "@hono/zod-validator": "^0.7.6",
    "bullmq": "^5.71.1",
    "drizzle-orm": "0.45.1",
    "hono": "^4.12.9",
    "ioredis": "5.10.1",
    "jose": "^6.2.2",
    "pino": "^10.3.1",
    "postgres": "^3.4.8",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/bun": "^1.3.11",
    "drizzle-kit": "^0.31.10",
    "pino-pretty": "^13.1.3",
    "typescript": "^6.0.2"
  }
}
